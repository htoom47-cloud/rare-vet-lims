# Cloud deployment (Render / Railway / similar)
NODE_ENV=production
PORT=5000
SERVE_FRONTEND=true
RUN_SEED=false

# Admin login (used on every deploy by ensure-admin.js)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@rarevetcare.com
ADMIN_INITIAL_PASSWORD=RareVet2026

# Provided automatically by Render/Railway when you attach PostgreSQL:
DATABASE_URL=postgresql://user:pass@host:5432/rare_vet_lims

# Or set manually:
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASSWORD=
# DB_NAME=rare_vet_lims

JWT_SECRET=change-to-64-char-random-secret
JWT_EXPIRES_IN=24h

# Set after first deploy to your public URLs:
APP_URL=https://lims.rarevetcare.com
STAFF_APP_URL=https://lims.rarevetcare.com
PORTAL_APP_URL=https://portal.rarevetcare.com
CORS_ORIGINS=https://lims.rarevetcare.com,https://portal.rarevetcare.com
CORS_ORIGIN=https://lims.rarevetcare.com
PORTAL_JWT_EXPIRES_IN=48h

STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Recommended for Render production (PDFs survive redeploy):
# STORAGE_TYPE=s3
# S3_BUCKET=rare-vet-lims-prod
# S3_REGION=me-south-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

LAB_NAME=مركز رعاية النوادر البيطري
LAB_NAME_AR=مركز رعاية النوادر البيطري
