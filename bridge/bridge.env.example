# Copy to bridge.env — values from LIMS → Lab Devices → Norma CBC
# LIMS cloud API (not the lab PC IP)
LIMS_API_URL=https://lims.rarevetcare.com/api
DEVICE_ID=your-device-uuid-here
DEVICE_API_KEY=your-api-key-here
LISTEN_PORT=21110

# On Norma iVet → Settings → LIS:
#   LIS IP   = IPv4 of THIS lab PC (run: ipconfig) e.g. 192.168.1.102
#   LIS port = 21110
#   HL7_1.0, Auto LIS transmission ON, Repeat Sample ID as Patient ID ON
# Sample ID on Norma = BC-... from tube label (LIMS shows SMP-... internally — same sample)
