# Copy to mindray-bridge.env — values from: node backend/src/scripts/setup-mindray-device.js
LIMS_API_URL=https://lims.rarevetcare.com/api
DEVICE_ID=your-mindray-device-uuid-here
DEVICE_API_KEY=your-api-key-here
LISTEN_PORT=5150

# On Mindray BS-120 → Setup → System → LIS:
#   Enable LIS: ON
#   LIS Host IP = IPv4 of THIS lab PC (ipconfig) e.g. 192.168.1.103
#   Port = 5150
#   Connect to LIS When Started Up: ON
#   Bidirectional Mode: OFF (initial setup)
# Sample ID = BC-... from tube label (same as Norma)
