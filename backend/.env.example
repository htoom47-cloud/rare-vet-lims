NODE_ENV=development
PORT=5000

# Cloud (Render / Railway)
# DATABASE_URL=postgresql://...
# SERVE_FRONTEND=true
# RUN_SEED=true
# APP_URL=https://your-app.onrender.com

DB_HOST=localhost
DB_PORT=5432
DB_USER=lims_user
DB_PASSWORD=lims_password
DB_NAME=rare_vet_lims

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Cloud storage (optional - S3 compatible)
# STORAGE_TYPE=s3
# S3_BUCKET=rare-vet-lims
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

LAB_NAME=Rare Animals Veterinary Care Center
LAB_NAME_AR=مركز رعاية النوادر البيطري
LAB_SUBTITLE=Veterinary Medical & Research Laboratory
LAB_SUBTITLE_AR=للتحاليل البيطرية والبحثية
LAB_ADDRESS=Kingdom of Saudi Arabia
LAB_PHONE=+966539779328
LAB_EMAIL=alnwader.10hz@gmail.com
VAT_NUMBER=300000000000003

# Notifications (Twilio — SMS & WhatsApp)
NOTIFICATION_PROVIDER=twilio
NOTIFICATION_DEFAULT_CHANNEL=sms
SMS_ENABLED=false
WHATSAPP_ENABLED=false
EMAIL_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
# Example WhatsApp sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
