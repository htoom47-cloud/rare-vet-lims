NODE_ENV=development
PORT=5000

# Cloud (Render / Railway)
# DATABASE_URL=postgresql://...
# SERVE_FRONTEND=true
# RUN_SEED=true
# APP_URL=https://your-app.onrender.com

DB_HOST=localhost
DB_PORT=5432
DB_USER=lims_user
DB_PASSWORD=lims_password
DB_NAME=rare_vet_lims

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
STAFF_APP_URL=http://localhost:5173
PORTAL_APP_URL=http://localhost:5174
# Production example:
# STAFF_APP_URL=https://lims.rarevetcare.com
# PORTAL_APP_URL=https://portal.rarevetcare.com
# CORS_ORIGINS=https://lims.rarevetcare.com,https://portal.rarevetcare.com
PORTAL_JWT_EXPIRES_IN=7d
# Temporary: same OTP for all portal customers (defaults to 1234 when SMS is off)
# PORTAL_OTP_STATIC=1234
# PORTAL_OTP_STATIC=off

STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Production file storage (S3 / Cloudflare R2 / MinIO — survives Render redeploys)
# STORAGE_TYPE=s3
# S3_BUCKET=rare-vet-lims-prod
# S3_REGION=me-south-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=          # optional — for R2/MinIO e.g. https://xxx.r2.cloudflarestorage.com

# Database backup (npm run backup — run from your PC with Render external DATABASE_URL)
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=30
# BACKUP_S3_PREFIX=backups/db

# Uploads backup — PDFs, reports, images (npm run backup:uploads)
# UPLOAD_BACKUP_ENABLED=false
# UPLOAD_BACKUP_DIR=./backups/uploads
# UPLOAD_BACKUP_RETENTION_DAYS=14
# UPLOAD_BACKUP_S3_PREFIX=backups/uploads

# Database SSL (production)
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_CA_CERT=          # optional PEM for strict TLS
# DATABASE_SSL=false         # disable SSL entirely (dev only)

LAB_NAME=AL NAWADER VETERINARY CARE CENTER
LAB_NAME_AR=مركز رعاية النوادر البيطري
LAB_SUBTITLE=Veterinary Medical & Research Laboratory
LAB_SUBTITLE_AR=للتحاليل البيطرية والبحثية
LAB_ADDRESS=Kingdom of Saudi Arabia
LAB_PHONE=0115007257
LAB_EMAIL=alnwader.10hz@gmail.com
VAT_NUMBER=311042487300003

# Lab report PDF design: 1 = compact bilingual (default, matches on-screen preview), 2 = premium, 3 = VetConnect HTML
REPORT_DESIGN=1

# Notifications — Msegat (SMS, Saudi Arabia) — recommended
NOTIFICATION_PROVIDER=msegat
NOTIFICATION_DEFAULT_CHANNEL=sms
SMS_ENABLED=false
MSEGAT_USERNAME=
MSEGAT_API_KEY=
MSEGAT_SENDER=
MSEGAT_MSG_ENCODING=UTF8

# Optional: Twilio (WhatsApp or international SMS)
WHATSAPP_ENABLED=false
EMAIL_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
# Example WhatsApp sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# Notifications dry-run (never send real messages when false)
SEND_REAL_NOTIFICATIONS=false

# Operational workflow flags (default off — current behaviour unchanged)
REQUIRE_INVOICE_BEFORE_BARCODE=false
REQUIRE_LAB_HANDOVER=false
LOCK_APPROVED_REPORTS=false
