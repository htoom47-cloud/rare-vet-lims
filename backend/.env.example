NODE_ENV=development
PORT=5000

# Cloud (Render / Railway)
# DATABASE_URL=postgresql://...
# SERVE_FRONTEND=true
# RUN_SEED=true
# APP_URL=https://your-app.onrender.com

DB_HOST=localhost
DB_PORT=5432
DB_USER=lims_user
DB_PASSWORD=lims_password
DB_NAME=rare_vet_lims

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Cloud storage (optional - S3 compatible)
# STORAGE_TYPE=s3
# S3_BUCKET=rare-vet-lims
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

LAB_NAME=Rare Veterinary Care
LAB_NAME_AR=رير للرعاية البيطرية
LAB_ADDRESS=Kingdom of Saudi Arabia
LAB_PHONE=+966500000000
LAB_EMAIL=lab@rarevetcare.com
VAT_NUMBER=300000000000003

# Future integrations
WHATSAPP_ENABLED=false
SMS_ENABLED=false
EMAIL_ENABLED=false
